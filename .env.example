# Server configuration
PORT=8080

# Google Gemini API key (Required for AI planning)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (gemini-1.5-flash is deprecated; use gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# RapidAPI Key for Indian Railways / IRCTC API (Optional - falls back to AI simulation if missing)
RAPIDAPI_KEY=your_rapidapi_key_here
