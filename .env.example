# Server configuration
PORT=8080

# Google Gemini Configuration
# Recommended stable model for free tier to avoid 503 high demand errors: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=your_gemini_api_key_here

# RailRadar API Configuration (Required for live Indian Railways trains and availability)
RAILRADAR_API_KEY=your_railradar_api_key_here
